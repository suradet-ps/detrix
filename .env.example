# Public env vars (available client-side via $env/static/public)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# For backward compatibility with VITE_ prefix (available via $env/dynamic/*)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Secret key for adding portfolio items (server-side only)
VITE_ADD_POST_SECRET_KEY=your-secret-key
